# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# From the OAuth client JSON you downloaded from Google Cloud Console:
# Open the JSON file, find "web" > "client_id" and "client_secret"
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# From Google AI Studio (aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — only needed if you switch model_config.yaml provider to "anthropic"
ANTHROPIC_API_KEY=

# Generate a strong random string for signing session cookies.
# Run this in Python to generate one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_key_here
